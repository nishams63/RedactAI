# Environment
ENVIRONMENT=development

# Database & Redis Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/redactai
REDIS_URL=redis://localhost:6379/0

# MinIO / S3 Compatible Object Storage
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=redactai-storage
MINIO_SECURE=False

# JWT Security
JWT_SECRET_KEY=PLACEHOLDER_JWT_SECRET_KEY_MINIMUM_32_CHARACTERS
JWT_REFRESH_SECRET_KEY=PLACEHOLDER_JWT_REFRESH_SECRET_KEY_MINIMUM_32_CHARACTERS
ENCRYPTION_KEY=PLACEHOLDER_32_BYTE_BASE64_FERNET_ENCRYPTION_KEY

# Token expiration and limits
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
PASSWORD_EXPIRATION_DAYS=0
MAX_ACTIVE_SESSIONS=5
SESSION_LIMIT_STRATEGY=terminate_oldest

# AI & Cache Configurations
HF_HOME=.cache/huggingface
MODEL_CACHE_DIR=.cache/models

# CORS Allowed Origins
CORS_ORIGINS=http://localhost:3000
