# Database & Cache Configurations
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/redactai
REDIS_URL=redis://localhost:6379/0

# MinIO / Object Storage Configurations
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=redactai-storage
MINIO_SECURE=False

# JWT & Cryptographic Security Keys
JWT_SECRET_KEY=PLACEHOLDER_JWT_SECRET_KEY_MINIMUM_32_CHARACTERS
JWT_REFRESH_SECRET_KEY=PLACEHOLDER_JWT_REFRESH_SECRET_KEY_MINIMUM_32_CHARACTERS
ENCRYPTION_KEY=PLACEHOLDER_32_BYTE_BASE64_FERNET_ENCRYPTION_KEY
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
PASSWORD_EXPIRATION_DAYS=0
MAX_ACTIVE_SESSIONS=5
SESSION_LIMIT_STRATEGY=terminate_oldest

# Application Client Configurations
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
